<section class="aarus-inner-circle color-{{ section.settings.color_scheme }} spacing-style{% if section.settings.show_background_pattern %} aarus-inner-circle--pattern{% endif %}" style="--padding-top: {{ section.settings.padding_top }}px; --padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width aarus-inner-circle__container">
    
    <div class="aarus-inner-circle__content">
      {% if section.settings.sticker_text != blank %}
        <span class="aarus-sticker aarus-sticker--accent aarus-inner-circle__sticker">{{ section.settings.sticker_text | escape }}</span>
      {% endif %}
      
      {% if section.settings.heading != blank %}
        <h2 class="h1 aarus-inner-circle__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      
      {% if section.settings.supporting_text != blank %}
        <p class="aarus-inner-circle__supporting-text">{{ section.settings.supporting_text | escape }}</p>
      {% endif %}
    </div>

    <div class="aarus-inner-circle__actions">
      <div class="aarus-inner-circle__form-wrapper">
        {% form 'customer', id: 'aarus-inner-circle-form', class: 'aarus-inner-circle__form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          
          <div class="aarus-inner-circle__form-fields">
            <div class="field">
              <input
                id="NewsletterForm--{{ section.id }}"
                type="email"
                name="contact[email]"
                class="field__input"
                value="{{ form.email }}"
                aria-required="true"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                {% if form.errors %}
                  autofocus
                  aria-invalid="true"
                  aria-describedby="Newsletter-error--{{ section.id }}"
                {% elsif form.posted_successfully? %}
                  aria-describedby="Newsletter-success--{{ section.id }}"
                {% endif %}
                placeholder="Enter your email"
                required
              >
              <label class="field__label visually-hidden" for="NewsletterForm--{{ section.id }}">
                Email address
              </label>
            </div>
            
            <button type="submit" class="button button--primary aarus-inner-circle__submit" name="commit" id="Subscribe-{{ section.id }}">
              {{ section.settings.email_button_text | escape }}
            </button>
          </div>

          {%- if form.errors -%}
            <small class="aarus-inner-circle__message aarus-inner-circle__message--error" id="Newsletter-error--{{ section.id }}">
              <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
              {{ section.settings.error_message | escape }}
            </small>
          {%- endif -%}

          {%- if form.posted_successfully? -%}
            <h3 class="aarus-inner-circle__message aarus-inner-circle__message--success" id="Newsletter-success--{{ section.id }}" tabindex="-1" autofocus>
              <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              {{ section.settings.success_message | escape }}
            </h3>
          {%- endif -%}

          {% if section.settings.consent_text != blank %}
            <div class="aarus-inner-circle__consent">
              <p>{{ section.settings.consent_text | escape }} 
                {% if section.settings.privacy_url != blank %}
                  <a href="{{ section.settings.privacy_url }}">Privacy Policy</a>.
                {% endif %}
              </p>
            </div>
          {% endif %}
        {% endform %}
      </div>

      {% if section.settings.whatsapp_url != blank %}
        <div class="aarus-inner-circle__divider"><span>or</span></div>
        <div class="aarus-inner-circle__whatsapp">
          {%- capture whatsapp_link -%}
            {{ section.settings.whatsapp_url }}{% if section.settings.whatsapp_message != blank %}?text={{ section.settings.whatsapp_message | url_encode }}{% endif %}
          {%- endcapture -%}
          
          <a href="{{ whatsapp_link }}" target="_blank" rel="noopener" class="button button--secondary aarus-inner-circle__whatsapp-btn">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            {{ section.settings.whatsapp_button_text | escape }}
          </a>
        </div>
      {% endif %}
    </div>

  </div>
</section>

{% stylesheet %}
  .aarus-inner-circle {
    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
    position: relative;
    overflow: hidden;
  }
  
  .aarus-inner-circle--pattern::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: radial-gradient(circle, currentColor 30%, transparent 40%);
    background-size: 16px 16px;
    background-repeat: repeat;
    opacity: 0.05;
    pointer-events: none;
    z-index: 0;
  }

  .aarus-inner-circle__container {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 3rem;
    align-items: center;
    max-width: 1000px;
    margin: 0 auto;
  }

  @media screen and (min-width: 900px) {
    .aarus-inner-circle__container {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }

  .aarus-inner-circle__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }

  .aarus-inner-circle__sticker {
    margin-bottom: 0.5rem;
  }

  .aarus-inner-circle__heading {
    margin: 0;
    font-family: var(--font-heading-family);
  }

  .aarus-inner-circle__supporting-text {
    font-size: 1.1rem;
    opacity: 0.9;
    margin: 0;
  }

  .aarus-inner-circle__actions {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    background: rgba(255,255,255,0.05);
    padding: 2rem;
    border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.1);
  }
  
  /* Form resets */
  .aarus-inner-circle__form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .aarus-inner-circle__form-fields {
    display: flex;
    gap: 0.5rem;
    width: 100%;
  }

  @media screen and (max-width: 480px) {
    .aarus-inner-circle__form-fields {
      flex-direction: column;
    }
  }
  
  .aarus-inner-circle__form-fields .field {
    flex-grow: 1;
  }
  
  .aarus-inner-circle__form-fields .field__input {
    width: 100%;
    background: rgba(255,255,255,0.1);
    color: inherit;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 8px;
    padding: 0.8rem 1rem;
  }

  .aarus-inner-circle__form-fields .field__input::placeholder {
    color: inherit;
    opacity: 0.6;
  }

  .aarus-inner-circle__form-fields .field__input:focus {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }
  
  .aarus-inner-circle__submit {
    min-width: max-content;
    border-radius: 8px;
  }

  .aarus-inner-circle__message {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    margin: 0;
  }
  
  .aarus-inner-circle__message--error {
    color: #ff5252;
  }
  
  .aarus-inner-circle__message--success {
    color: #4caf50;
  }

  .aarus-inner-circle__consent {
    font-size: 0.8rem;
    opacity: 0.7;
    margin: 0;
  }
  
  .aarus-inner-circle__consent a {
    color: inherit;
    text-decoration: underline;
  }

  .aarus-inner-circle__divider {
    display: flex;
    align-items: center;
    text-align: center;
    color: inherit;
    opacity: 0.5;
  }
  
  .aarus-inner-circle__divider::before,
  .aarus-inner-circle__divider::after {
    content: '';
    flex: 1;
    border-bottom: 1px dashed currentColor;
  }
  
  .aarus-inner-circle__divider span {
    padding: 0 1rem;
    font-size: 0.9rem;
    font-style: italic;
  }

  .aarus-inner-circle__whatsapp {
    display: flex;
  }
  
  .aarus-inner-circle__whatsapp-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    background: transparent;
    color: inherit;
    border-color: currentColor;
    border-radius: 8px;
  }

  .aarus-inner-circle__whatsapp-btn:hover {
    background: rgba(255,255,255,0.1);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Inner Circle",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the inner circle."
    },
    {
      "type": "textarea",
      "id": "supporting_text",
      "label": "Supporting copy",
      "default": "Get first access to festive drops, styling inspo, and small-batch releases."
    },
    {
      "type": "text",
      "id": "sticker_text",
      "label": "Sticker text",
      "default": "Early access"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-3"
    },
    {
      "type": "checkbox",
      "id": "show_background_pattern",
      "label": "Show Bandhani dot pattern background",
      "default": true
    },
    {
      "type": "header",
      "content": "Email Settings"
    },
    {
      "type": "text",
      "id": "email_button_text",
      "label": "Button text",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "You're in. Watch your inbox for the good stuff."
    },
    {
      "type": "text",
      "id": "error_message",
      "label": "Error message",
      "default": "That email did not go through. Try again?"
    },
    {
      "type": "text",
      "id": "consent_text",
      "label": "Consent text",
      "default": "By signing up, you agree to receive marketing emails."
    },
    {
      "type": "url",
      "id": "privacy_url",
      "label": "Privacy policy link"
    },
    {
      "type": "header",
      "content": "WhatsApp Settings"
    },
    {
      "type": "url",
      "id": "whatsapp_url",
      "label": "WhatsApp URL",
      "info": "Leave blank to hide WhatsApp button. Example: https://wa.me/1234567890"
    },
    {
      "type": "text",
      "id": "whatsapp_button_text",
      "label": "Button text",
      "default": "Chat with us on WhatsApp"
    },
    {
      "type": "text",
      "id": "whatsapp_message",
      "label": "Prefilled message",
      "default": "Hi Aarus, I'd love help choosing a festive look."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Aarus Inner Circle"
    }
  ]
}
{% endschema %}
