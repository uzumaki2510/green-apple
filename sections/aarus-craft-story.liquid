{%- style -%}
  .aarus-craft-story-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .aarus-craft-story-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .aarus-craft-story__container {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    max-width: var(--page-width, 1400px);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media screen and (min-width: 990px) {
    .aarus-craft-story__container {
      flex-direction: row;
      align-items: center;
      gap: 5rem;
      padding: 0 3rem;
    }
    
    .aarus-craft-story--image-right .aarus-craft-story__container {
      flex-direction: row-reverse;
    }
  }

  /* Images Column */
  .aarus-craft-story__images-wrapper {
    flex: 1;
    width: 100%;
  }

  .aarus-craft-story__images {
    display: flex;
    gap: 1rem;
    align-items: stretch;
  }

  .aarus-craft-story__image-main-wrap {
    flex: 2;
    position: relative;
    border-radius: 2px;
    overflow: hidden;
  }

  .aarus-craft-story__image-details-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .aarus-craft-story__image-detail {
    flex: 1;
    position: relative;
    border-radius: 2px;
    overflow: hidden;
  }

  .aarus-craft-story__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    position: absolute;
    inset: 0;
  }

  .aarus-craft-story__image-main-wrap::before {
    content: "";
    display: block;
    padding-bottom: 125%; /* 4:5 aspect ratio */
  }

  /* Content Column */
  .aarus-craft-story__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .aarus-craft-story__microcopy {
    font-family: var(--font-body-family);
    font-size: 0.9rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin: 0 0 1rem 0;
    opacity: 0.7;
    font-weight: 600;
  }

  .aarus-craft-story__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(2.5rem, 4vw, 4rem);
    line-height: 1;
    font-weight: 800;
    margin: 0 0 1.5rem 0;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .aarus-craft-story__body {
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    max-width: 600px;
  }

  .aarus-craft-story__body p {
    margin: 0 0 1rem 0;
  }
  .aarus-craft-story__body p:last-child {
    margin-bottom: 0;
  }

  .aarus-craft-story__quote {
    font-family: var(--font-heading-family);
    font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    line-height: 1.4;
    font-style: italic;
    border-left: 4px solid currentColor;
    padding-left: 1.5rem;
    margin: 0 0 2.5rem 0;
    opacity: 0.9;
    font-weight: 600;
  }

  /* Textile-inspired separator (Stitched line) */
  .aarus-craft-story__stitch {
    width: 100%;
    height: 2px;
    background-image: linear-gradient(to right, currentColor 40%, transparent 40%);
    background-size: 12px 2px;
    background-repeat: repeat-x;
    opacity: 0.2;
    margin: 2rem 0;
  }

  /* Craft Facts */
  .aarus-craft-story__facts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media screen and (min-width: 500px) {
    .aarus-craft-story__facts {
      grid-template-columns: 1fr 1fr;
      gap: 2rem 1.5rem;
    }
  }

  .aarus-craft-story__fact {
    display: flex;
    flex-direction: column;
  }

  .aarus-craft-story__fact-title {
    font-weight: 700;
    font-family: var(--font-heading-family);
    margin-bottom: 0.4rem;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    color: rgb(var(--color-foreground));
  }

  .aarus-craft-story__fact-text {
    font-size: 0.95rem;
    line-height: 1.5;
    opacity: 0.85;
    margin: 0;
  }

{%- endstyle -%}

<section class="aarus-craft-story-{{ section.id }} color-{{ section.settings.color_scheme }} aarus-craft-story--image-{{ section.settings.image_position }}" data-section-id="{{ section.id }}">
  <div class="aarus-craft-story__container">
    
    <!-- Images Column -->
    <div class="aarus-craft-story__images-wrapper">
      <div class="aarus-craft-story__images">
        
        <div class="aarus-craft-story__image-main-wrap">
          {%- if section.settings.image_main != blank -%}
            <img src="{{ section.settings.image_main | image_url: width: 1200 }}"
                 alt="{{ section.settings.image_main.alt | escape }}"
                 class="aarus-craft-story__img"
                 loading="lazy"
                 width="{{ section.settings.image_main.width }}"
                 height="{{ section.settings.image_main.height }}">
          {%- else -%}
            {{ 'detailed-apparel-1' | placeholder_svg_tag: 'aarus-craft-story__img placeholder-svg' }}
          {%- endif -%}
        </div>

        {%- if section.settings.image_detail_1 != blank or section.settings.image_detail_2 != blank -%}
          <div class="aarus-craft-story__image-details-wrap">
            {%- if section.settings.image_detail_1 != blank -%}
              <div class="aarus-craft-story__image-detail">
                <img src="{{ section.settings.image_detail_1 | image_url: width: 600 }}"
                     alt="{{ section.settings.image_detail_1.alt | escape }}"
                     class="aarus-craft-story__img"
                     loading="lazy"
                     width="{{ section.settings.image_detail_1.width }}"
                     height="{{ section.settings.image_detail_1.height }}">
              </div>
            {%- endif -%}
            
            {%- if section.settings.image_detail_2 != blank -%}
              <div class="aarus-craft-story__image-detail">
                <img src="{{ section.settings.image_detail_2 | image_url: width: 600 }}"
                     alt="{{ section.settings.image_detail_2.alt | escape }}"
                     class="aarus-craft-story__img"
                     loading="lazy"
                     width="{{ section.settings.image_detail_2.width }}"
                     height="{{ section.settings.image_detail_2.height }}">
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

      </div>
    </div>

    <!-- Content Column -->
    <div class="aarus-craft-story__content">
      
      {%- if section.settings.microcopy != blank -%}
        <p class="aarus-craft-story__microcopy">{{ section.settings.microcopy }}</p>
      {%- endif -%}
      
      {%- if section.settings.heading != blank -%}
        <h2 class="aarus-craft-story__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      
      {%- if section.settings.body_text != blank -%}
        <div class="aarus-craft-story__body">{{ section.settings.body_text }}</div>
      {%- endif -%}
      
      {%- if section.settings.quote != blank -%}
        <blockquote class="aarus-craft-story__quote">
          &ldquo;{{ section.settings.quote }}&rdquo;
        </blockquote>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="aarus-craft-story__stitch" aria-hidden="true"></div>
        
        <ul class="aarus-craft-story__facts">
          {%- for block in section.blocks -%}
            <li class="aarus-craft-story__fact" {{ block.shopify_attributes }}>
              <span class="aarus-craft-story__fact-title">{{ block.settings.title }}</span>
              <p class="aarus-craft-story__fact-text">{{ block.settings.text }}</p>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Storytelling",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Desktop Image Position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_main",
      "label": "Main Image",
      "info": "Large vertical image. Recommended aspect ratio 4:5"
    },
    {
      "type": "image_picker",
      "id": "image_detail_1",
      "label": "Detail Image 1 (Optional)",
      "info": "Stacks next to the main image."
    },
    {
      "type": "image_picker",
      "id": "image_detail_2",
      "label": "Detail Image 2 (Optional)",
      "info": "Stacks next to the main image."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "microcopy",
      "label": "Gujarati / Hindi Microcopy (Optional)",
      "info": "E.g., 'હસ્તકલા' (Handicraft). Leave blank to hide."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From craft to celebration"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body Text",
      "default": "<p>Discover the intricate details and hand-finished touches that make our collections special. We highlight the artistry behind each piece.</p>"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Short Quote",
      "default": "Every thread tells a story of tradition."
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 48
    }
  ],
  "max_blocks": 4,
  "blocks": [
    {
      "type": "fact",
      "name": "Craft Fact",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Fact Title",
          "default": "Embroidery"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Fact Text",
          "default": "Detailed mirror work taking hours to complete."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Storytelling",
      "blocks": [
        {
          "type": "fact",
          "settings": {
            "title": "Embroidery",
            "text": "Intricate hand-stitched details that celebrate our textile heritage."
          }
        },
        {
          "type": "fact",
          "settings": {
            "title": "Mirror Work",
            "text": "Reflecting the joy and energy of festive gatherings."
          }
        }
      ]
    }
  ]
}
{% endschema %}
