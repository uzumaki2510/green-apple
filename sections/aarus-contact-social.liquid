{{ 'aarus-contact.css' | asset_url | stylesheet_tag }}

<section class="aarus-contact-section color-{{ section.settings.color_scheme }}" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="aarus-contact-container">
    
    <div class="aarus-contact-social__wrapper">
      
      <div class="aarus-contact-social__content">
        {% if section.settings.heading != blank %}
          <h2 class="h1" style="font-family: var(--font-heading-family); margin-bottom: 1rem; color: inherit;">{{ section.settings.heading | escape }}</h2>
        {% endif %}
        
        {% if section.settings.body != blank %}
          <p style="font-size: 1.2rem; opacity: 0.9; margin-bottom: 2rem;">{{ section.settings.body | escape }}</p>
        {% endif %}

        {% if section.settings.social_handle != blank %}
          <p style="font-family: var(--font-heading-family); font-weight: 700; font-size: 1.5rem; color: var(--aarus-rani-pink); margin-bottom: 2rem;">
            {{ section.settings.social_handle | escape }}
          </p>
        {% endif %}

        <div class="aarus-contact-social__links">
          {% if section.settings.instagram_url != blank %}
            <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" class="aarus-contact-social__link">
              <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
              Instagram
            </a>
          {% endif %}
          
          {% if section.settings.pinterest_url != blank %}
            <a href="{{ section.settings.pinterest_url }}" target="_blank" rel="noopener" class="aarus-contact-social__link">
              <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.256 2.662 7.915 6.425 9.324-.055-.783-.105-1.986.022-2.846.114-.775.735-3.116.735-3.116s-.188-.376-.188-.933c0-.874.507-1.526 1.139-1.526.537 0 .796.403.796.886 0 .54-.344 1.348-.521 2.097-.149.627.315 1.138.932 1.138 1.118 0 1.977-1.18 1.977-2.884 0-1.508-1.085-2.563-2.637-2.563-1.789 0-2.84 1.343-2.84 2.73 0 .542.209 1.123.47 1.439.043.052.049.098.036.148l-.151.624c-.021.086-.07.104-.158.063-.59-.276-.957-1.144-.957-1.838 0-1.496 1.087-2.868 3.136-2.868 1.644 0 2.923 1.171 2.923 2.734 0 1.634-1.03 2.949-2.459 2.949-.48 0-.932-.25-1.087-.544l-.296 1.129c-.107.41-.397.923-.591 1.236A9.953 9.953 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2z"/></svg>
              Pinterest
            </a>
          {% endif %}

          {% if section.settings.whatsapp_url != blank %}
            <a href="{{ section.settings.whatsapp_url }}" target="_blank" rel="noopener" class="aarus-contact-social__link">
              <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
              WhatsApp Community
            </a>
          {% endif %}
        </div>
      </div>

      <div class="aarus-contact-social__media">
        {% if section.settings.video != blank %}
          {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, image_size: '800x' }}
        {% elsif section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: section.settings.heading }}
        {% else %}
          <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.05);">
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {% endif %}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Social Community",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Show us your Aarus moment."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Tag us in your festive looks, twirls, and celebration-ready styling."
    },
    {
      "type": "text",
      "id": "social_handle",
      "label": "Social handle",
      "default": "@aaruscreations"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section color scheme",
      "default": "scheme-3"
    },
    {
      "type": "header",
      "content": "Links"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL",
      "default": "https://instagram.com"
    },
    {
      "type": "url",
      "id": "pinterest_url",
      "label": "Pinterest URL"
    },
    {
      "type": "url",
      "id": "whatsapp_url",
      "label": "WhatsApp Group URL"
    },
    {
      "type": "header",
      "content": "Media Spotlight"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image spotlight"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video spotlight",
      "info": "Overrides image if provided."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Aarus Contact Social"
    }
  ]
}
{% endschema %}
