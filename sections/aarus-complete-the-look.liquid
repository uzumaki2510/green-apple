<style>
  .aarus-complete-look-{{ section.id }} {
    --complete-look-desktop-height: {{ section.settings.desktop_image_height }}px;
    --complete-look-mobile-height: {{ section.settings.mobile_image_height }}px;
    --complete-look-gap: {{ section.settings.gap }}px;
    --complete-look-desktop-products: {{ section.settings.desktop_products }};
    --complete-look-mobile-products: {{ section.settings.mobile_products }};
  }

  .aarus-complete-look {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: var(--color-background);
  }

  .aarus-complete-look__grid {
    display: flex;
    gap: var(--complete-look-gap);
  }

  .aarus-complete-look__item {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 0 0 calc((100% - (var(--complete-look-desktop-products) - 1) * var(--complete-look-gap)) / var(--complete-look-desktop-products));
  }

  .aarus-complete-look__media {
    width: 100%;
    height: var(--complete-look-desktop-height);
    overflow: hidden;
    background: var(--color-background);
    border-radius: 12px;
  }

  .aarus-complete-look__media--square { aspect-ratio: 1 / 1; }
  .aarus-complete-look__media--4-5 { aspect-ratio: 4 / 5; }
  .aarus-complete-look__media--portrait { aspect-ratio: 2 / 3; }
  .aarus-complete-look__media--auto { aspect-ratio: auto; height: auto; }

  .aarus-complete-look__media img {
    width: 100%;
    height: 100%;
    display: block;
    object-position: center;
  }

  .aarus-complete-look__media--cover img {
    object-fit: cover;
  }

  .aarus-complete-look__media--contain img {
    object-fit: contain;
  }

  .aarus-complete-look__details {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .aarus-complete-look__product-title {
    font-family: var(--font-heading-family);
    font-size: 1.1rem;
    text-decoration: none;
    font-weight: 700;
  }
  
  .aarus-complete-look__price {
    font-size: 0.95rem;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .aarus-complete-look__grid {
      flex-wrap: nowrap;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .aarus-complete-look__grid::-webkit-scrollbar {
      display: none;
    }
    .aarus-complete-look__item {
      flex: 0 0 calc((100% - (var(--complete-look-mobile-products) - 1) * var(--complete-look-gap)) / var(--complete-look-mobile-products));
      scroll-snap-align: start;
    }
    .aarus-complete-look__media {
      height: var(--complete-look-mobile-height);
    }
  }

  /* Optional width sizing if required by user setting */
  .aarus-complete-look__media-width--small { max-width: 80%; margin: 0 auto; }
  .aarus-complete-look__media-width--medium { max-width: 90%; margin: 0 auto; }
  .aarus-complete-look__media-width--large { max-width: 100%; margin: 0 auto; }

</style>

<section class="aarus-complete-look aarus-complete-look-{{ section.id }} color-{{ section.settings.color_scheme }}" data-section-id="{{ section.id }}">
  <div class="page-width">
    {% if section.settings.title != blank %}
      <h2 class="aarus-complete-look__title h2" style="text-align: center; margin-bottom: 2rem;">{{ section.settings.title | escape }}</h2>
    {% endif %}
    
    <div class="aarus-complete-look__grid">
      {% assign max_products = section.settings.max_products %}
      {% assign product_count = 0 %}
      {% assign current_tags = product.tags | join: ',' | downcase %}
      
      {% for collection in product.collections %}
        {% if product_count >= max_products %}{% break %}{% endif %}
        {% for cross_product in collection.products %}
          {% if product_count >= max_products %}{% break %}{% endif %}
          
          {% if cross_product.id != product.id %}
            {% assign match_found = false %}
            {% for tag in cross_product.tags %}
              {% assign tag_down = tag | downcase %}
              {% if current_tags contains tag_down and tag_down contains 'cross-sell' %}
                {% assign match_found = true %}
                {% break %}
              {% endif %}
            {% endfor %}
            
            {% if match_found %}
              <div class="aarus-complete-look__item">
                {%- capture media_classes -%}
                  aarus-complete-look__media aarus-complete-look__media--{{ section.settings.image_aspect_ratio }} aarus-complete-look__media--{{ section.settings.image_fit }} aarus-complete-look__media-width--{{ section.settings.image_width }}
                {%- endcapture -%}
                <a href="{{ cross_product.url }}" class="{{ media_classes | strip }}">
                  {{ cross_product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy' }}
                </a>
                
                <div class="aarus-complete-look__details">
                  {% if section.settings.show_title %}
                    <a href="{{ cross_product.url }}" class="aarus-complete-look__product-title">{{ cross_product.title }}</a>
                  {% endif %}
                  {% if section.settings.show_price %}
                    <p class="aarus-complete-look__price">{{ cross_product.price | money }}</p>
                  {% endif %}
                  
                  {% if section.settings.show_add_to_cart %}
                    {% if cross_product.available %}
                      {% form 'product', cross_product, data-type: 'add-to-cart-form' %}
                        <input type="hidden" name="id" value="{{ cross_product.variants.first.id }}">
                        <button type="submit" class="button button--secondary button--small aarus-complete-look__add" style="width: 100%;">Add to cart</button>
                      {% endform %}
                    {% else %}
                      <button type="button" class="button button--secondary button--small aarus-complete-look__add" disabled style="width: 100%;">Sold out</button>
                    {% endif %}
                  {% endif %}
                </div>
              </div>
              {% assign product_count = product_count | plus: 1 %}
            {% endif %}
          {% endif %}
        {% endfor %}
      {% endfor %}
      
      {% if product_count == 0 %}
        <!-- Fallback if no tag matches -->
        {% for cross_product in collections.all.products limit: max_products %}
          {% if cross_product.id != product.id and cross_product.available %}
            <div class="aarus-complete-look__item">
              {%- capture media_classes -%}
                aarus-complete-look__media aarus-complete-look__media--{{ section.settings.image_aspect_ratio }} aarus-complete-look__media--{{ section.settings.image_fit }} aarus-complete-look__media-width--{{ section.settings.image_width }}
              {%- endcapture -%}
              <a href="{{ cross_product.url }}" class="{{ media_classes | strip }}">
                {{ cross_product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy' }}
              </a>
              <div class="aarus-complete-look__details">
                {% if section.settings.show_title %}
                  <a href="{{ cross_product.url }}" class="aarus-complete-look__product-title">{{ cross_product.title }}</a>
                {% endif %}
                {% if section.settings.show_price %}
                  <p class="aarus-complete-look__price">{{ cross_product.price | money }}</p>
                {% endif %}
                {% if section.settings.show_add_to_cart %}
                  {% form 'product', cross_product, data-type: 'add-to-cart-form' %}
                    <input type="hidden" name="id" value="{{ cross_product.variants.first.id }}">
                    <button type="submit" class="button button--secondary button--small aarus-complete-look__add" style="width: 100%;">Add to cart</button>
                  {% endform %}
                {% endif %}
              </div>
            </div>
            {% assign product_count = product_count | plus: 1 %}
          {% endif %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Complete the Look",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Complete the Look"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "max_products",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Maximum products to query",
      "default": 4
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        { "value": "square", "label": "Square" },
        { "value": "4-5", "label": "4:5" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "auto", "label": "Auto" }
      ],
      "default": "4-5"
    },
    {
      "type": "range",
      "id": "desktop_image_height",
      "min": 100,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Image height on desktop",
      "default": 320
    },
    {
      "type": "range",
      "id": "mobile_image_height",
      "min": 100,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Image height on mobile",
      "default": 190
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image fit",
      "options": [
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" }
      ],
      "default": "cover"
    },
    {
      "type": "select",
      "id": "image_width",
      "label": "Image width",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "large"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_products",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Number of products on desktop",
      "default": 4
    },
    {
      "type": "range",
      "id": "mobile_products",
      "min": 1,
      "max": 4,
      "step": 0.5,
      "label": "Number of products on mobile",
      "default": 2
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Gap between products",
      "default": 16
    },
    {
      "type": "header",
      "content": "Product Options"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show product title",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_add_to_cart",
      "label": "Show Add to Cart button",
      "default": true
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Complete the Look"
    }
  ],
  "templates": ["product"]
}
{% endschema %}
