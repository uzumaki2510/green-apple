{{ 'aarus-contact.css' | asset_url | stylesheet_tag }}

<section class="aarus-contact-section color-{{ section.settings.color_scheme }}" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; position: relative;">
  
  {% if section.settings.show_decoration %}
    <div class="aarus-separator-bandhani" style="position: absolute; top: 0; left: 0; right: 0;"></div>
    <div class="aarus-separator-ajrakh" style="position: absolute; bottom: 0; left: 0; right: 0;"></div>
  {% endif %}

  <div class="aarus-contact-container">
    <div class="aarus-contact-story__grid">
      
      <div style="max-width: 500px;">
        {% if section.settings.heading != blank %}
          <h2 class="h1" style="font-family: var(--font-heading-family); color: inherit; margin-bottom: 1.5rem;">{{ section.settings.heading | escape }}</h2>
        {% endif %}
        {% if section.settings.body != blank %}
          <p style="font-size: 1.2rem; opacity: 0.9;">{{ section.settings.body | escape }}</p>
        {% endif %}
      </div>

      <div class="aarus-contact-story__content">
        {% if section.settings.show_decoration %}
          <svg class="aarus-contact-story__decoration" width="120" height="120" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="60" cy="60" r="59" stroke="var(--aarus-marigold)" stroke-width="2" stroke-dasharray="4 8"/>
            <circle cx="60" cy="60" r="45" stroke="var(--aarus-rani-pink)" stroke-width="1" stroke-dasharray="2 4"/>
          </svg>
        {% endif %}
        
        <ul class="aarus-contact-story__list">
          {% for block in section.blocks %}
            <li class="aarus-contact-story__item" {{ block.shopify_attributes }}>
              <svg class="aarus-contact-story__icon" viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><circle cx="12" cy="12" r="10"></circle><path d="M8 14s1.5 2 4 2 4-2 4-2"></path><line x1="9" y1="9" x2="9.01" y2="9"></line><line x1="15" y1="9" x2="15.01" y2="9"></line></svg>
              <span>{{ block.settings.fact | escape }}</span>
            </li>
          {% endfor %}
        </ul>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Story",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From our hands to your celebration."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Aarus Creations brings together festive color, thoughtful details, and pieces made to be worn, styled, and remembered."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section color scheme",
      "default": "scheme-4"
    },
    {
      "type": "checkbox",
      "id": "show_decoration",
      "label": "Show textile decorations",
      "default": true
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "fact",
      "name": "Fact",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "fact",
          "label": "Fact",
          "default": "Festive wear and accessories"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Aarus Contact Story",
      "blocks": [
        {
          "type": "fact",
          "settings": {
            "fact": "Festive wear and accessories"
          }
        },
        {
          "type": "fact",
          "settings": {
            "fact": "Styling help when you need it"
          }
        },
        {
          "type": "fact",
          "settings": {
            "fact": "Small-batch drops and special requests"
          }
        }
      ]
    }
  ]
}
{% endschema %}
