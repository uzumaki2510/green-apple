{{ 'aarus-contact.css' | asset_url | stylesheet_tag }}

<section class="aarus-contact-section aarus-contact-options color-{{ section.settings.color_scheme }}" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="aarus-contact-container">
    
    {% if section.settings.heading != blank %}
      <div style="text-align: center; margin-bottom: 4rem;">
        <h2 class="h1" style="margin: 0; font-family: var(--font-heading-family); color: inherit;">{{ section.settings.heading | escape }}</h2>
      </div>
    {% endif %}

    <div class="aarus-contact-options__grid">
      {% for block in section.blocks %}
        <div class="aarus-contact-options__card color-{{ block.settings.color_scheme }}" {{ block.shopify_attributes }}>
          
          <h3 class="h3 aarus-contact-options__heading">{{ block.settings.heading | escape }}</h3>
          <p class="aarus-contact-options__body">{{ block.settings.body | escape }}</p>
          
          {% if block.settings.button_link != blank %}
            <a href="{{ block.settings.button_link }}" class="button button--secondary aarus-contact-options__button">
              {{ block.settings.button_label | escape }}
            </a>
          {% endif %}
          
        </div>
      {% endfor %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Contact Options",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Pick your way to reach us."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "contact_method",
      "name": "Contact Method",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Need a quick answer?"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Supporting copy",
          "default": "Chat with us about sizing, styling, or your order."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Message us"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "label": "Card color scheme",
          "default": "scheme-2"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Aarus Contact Options",
      "blocks": [
        {
          "type": "contact_method",
          "settings": {
            "heading": "Need a quick answer?",
            "body": "Chat with us about sizing, styling, or your order.",
            "button_label": "Message us",
            "color_scheme": "scheme-2"
          }
        },
        {
          "type": "contact_method",
          "settings": {
            "heading": "Prefer email?",
            "body": "Send your question and we’ll get back to you.",
            "button_label": "Email Aarus",
            "color_scheme": "scheme-3"
          }
        },
        {
          "type": "contact_method",
          "settings": {
            "heading": "Have something special in mind?",
            "body": "Tell us about your occasion, colors, size, or styling idea.",
            "button_label": "Request a custom order",
            "color_scheme": "scheme-4"
          }
        },
        {
          "type": "contact_method",
          "settings": {
            "heading": "Checking an order?",
            "body": "Keep your order number ready and we’ll help you track it.",
            "button_label": "Get order help",
            "color_scheme": "scheme-1"
          }
        }
      ]
    }
  ]
}
{% endschema %}
