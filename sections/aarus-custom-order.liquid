<section class="aarus-custom-order color-{{ section.settings.color_scheme }} spacing-style" style="--padding-top: {{ section.settings.padding_top }}px; --padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width aarus-custom-order__container{% if section.settings.image != blank %} aarus-custom-order__container--with-image{% endif %}">
    
    <div class="aarus-custom-order__content">
      {% if section.settings.sticker_text != blank %}
        <span class="aarus-sticker aarus-sticker--dark aarus-custom-order__sticker">{{ section.settings.sticker_text | escape }}</span>
      {% endif %}
      
      {% if section.settings.eyebrow != blank %}
        <p class="aarus-custom-order__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}
      
      {% if section.settings.heading != blank %}
        <h2 class="h1 aarus-custom-order__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      
      {% if section.settings.body != blank %}
        <p class="aarus-custom-order__body">{{ section.settings.body | escape }}</p>
      {% endif %}
      
      <div class="aarus-custom-order__actions">
        {% if section.settings.button_link != blank %}
          <a href="{{ section.settings.button_link }}" class="button button--primary">
            {{ section.settings.button_text | escape }}
          </a>
        {% endif %}
        
        {% if section.settings.whatsapp_url != blank %}
          <a href="{{ section.settings.whatsapp_url }}" target="_blank" rel="noopener" class="button button--secondary aarus-custom-order__whatsapp">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            {{ section.settings.whatsapp_text | escape }}
          </a>
        {% endif %}
      </div>
    </div>
    
    {% if section.settings.image != blank %}
      <div class="aarus-custom-order__media">
        {{ section.settings.image | image_url: width: 1200 | image_tag: class: 'aarus-custom-order__image', loading: 'lazy', alt: section.settings.image.alt | default: section.settings.heading }}
      </div>
    {% endif %}

  </div>
</section>

{% stylesheet %}
  .aarus-custom-order {
    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
    background-color: var(--color-background);
  }

  .aarus-custom-order__container {
    display: grid;
    gap: 3rem;
    align-items: center;
  }

  @media screen and (min-width: 900px) {
    .aarus-custom-order__container--with-image {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }

  .aarus-custom-order__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
    max-width: 600px;
  }

  .aarus-custom-order__sticker {
    margin-bottom: 0.5rem;
  }

  .aarus-custom-order__eyebrow {
    font-family: var(--font-heading-family);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.9rem;
    font-weight: 700;
    margin: 0;
    color: var(--aarus-mehndi);
  }

  .aarus-custom-order__heading {
    margin: 0;
  }

  .aarus-custom-order__body {
    font-size: 1.1rem;
    margin: 0;
    opacity: 0.9;
  }

  .aarus-custom-order__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1rem;
  }

  .aarus-custom-order__whatsapp {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .aarus-custom-order__media {
    width: 100%;
    aspect-ratio: 4/5;
    border-radius: 16px;
    overflow: hidden;
  }

  .aarus-custom-order__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Custom Order CTA",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Made your way"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Need something a little more you?"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Tell us what you’re dreaming of and our team will help you explore a custom festive look, coordinated accessories, or a special-size request."
    },
    {
      "type": "text",
      "id": "sticker_text",
      "label": "Sticker text",
      "default": "Small batch"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Request a custom order"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "WhatsApp Support"
    },
    {
      "type": "url",
      "id": "whatsapp_url",
      "label": "WhatsApp URL",
      "info": "Leave blank to hide. Example: https://wa.me/1234567890"
    },
    {
      "type": "text",
      "id": "whatsapp_text",
      "label": "Button text",
      "default": "WhatsApp us"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Aarus Custom Order CTA"
    }
  ]
}
{% endschema %}
