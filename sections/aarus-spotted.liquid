{%- style -%}
  .aarus-spotted-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .aarus-spotted-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .aarus-spotted__header {
    text-align: center;
    margin-bottom: 2rem;
    padding: 0 1.5rem;
  }

  .aarus-spotted__title {
    font-family: var(--font-heading-family);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    margin: 0;
  }

  /* Mobile Layout: Horizontal Scroll Snap */
  .aarus-spotted__grid {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: 1.5rem;
    padding: 0 1.5rem 2rem 1.5rem;
    -webkit-overflow-scrolling: touch;
    scroll-padding-left: 1.5rem;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .aarus-spotted__grid::-webkit-scrollbar {
    display: none;
  }

  .aarus-spotted__grid::after {
    content: '';
    flex: 0 0 1px;
    width: 1px;
    padding-right: 0.5rem;
  }

  .aarus-spotted__card {
    flex: 0 0 85vw;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    /* Visible keyboard focus */
    outline: none;
    border-radius: 4px;
  }

  .aarus-spotted__card:focus-within {
    outline: 3px solid currentColor;
    outline-offset: 4px;
  }

  .aarus-spotted__media-container {
    position: relative;
    width: 100%;
    aspect-ratio: 4/5;
    border-radius: 2px;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .aarus-spotted__image,
  .aarus-spotted__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: inherit;
  }

  /* Product Tag Overlay */
  .aarus-spotted__tag {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    background-color: rgb(var(--color-button, 0,0,0));
    color: rgb(var(--color-button-text, 255,255,255));
    padding: 0.4rem 0.8rem;
    border-radius: 2px; /* Sharp editorial */
    font-family: var(--font-heading-family);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    box-shadow: 2px 2px 0px rgba(0,0,0,0.15);
    z-index: 5;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .aarus-spotted__tag:hover,
  .aarus-spotted__tag:focus-visible {
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0px rgba(0,0,0,0.2);
  }

  /* Info Section */
  .aarus-spotted__info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-bottom: 1rem;
  }

  .aarus-spotted__author {
    font-family: var(--font-heading-family);
    font-weight: 700;
    font-size: 1.1rem;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .aarus-spotted__handle {
    font-family: var(--font-body-family);
    font-weight: 400;
    font-size: 0.9rem;
    opacity: 0.7;
  }

  .aarus-spotted__caption {
    font-family: var(--font-body-family);
    font-size: 0.95rem;
    line-height: 1.4;
    margin: 0;
  }

  /* Desktop Layout: Irregular Editorial Row */
  @media screen and (min-width: 750px) {
    .aarus-spotted__header {
      margin-bottom: 4rem;
    }

    .aarus-spotted__grid {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: flex-start;
      gap: 2rem;
      padding: 0 3rem 4rem 3rem;
      max-width: var(--page-width, 1400px);
      margin: 0 auto;
      overflow: visible;
    }

    .aarus-spotted__grid::after {
      display: none;
    }

    .aarus-spotted__card {
      flex: none;
      width: calc(25% - 1.5rem); /* Default ~4 columns */
      margin-top: 0;
    }

    /* Staggering logic for organic editorial feel */
    .aarus-spotted__card:nth-child(even) {
      margin-top: 3rem;
    }

    .aarus-spotted__card:nth-child(3n) {
      width: calc(30% - 1.5rem);
    }

    .aarus-spotted__card:nth-child(4n) {
      width: calc(20% - 1.5rem);
      margin-top: -1rem;
    }
  }

{%- endstyle -%}

<section class="aarus-spotted-{{ section.id }} color-{{ section.settings.color_scheme }}" data-section-id="{{ section.id }}">
  {%- if section.settings.title != blank -%}
    <div class="aarus-spotted__header">
      <h2 class="aarus-spotted__title">{{ section.settings.title }}</h2>
    </div>
  {%- endif -%}

  <div class="aarus-spotted__grid">
    {%- for block in section.blocks -%}
      <div class="aarus-spotted__card" {{ block.shopify_attributes }}>
        
        <div class="aarus-spotted__media-container">
          {%- if block.settings.video != blank -%}
            {%- liquid
              assign poster = block.settings.poster_image | default: block.settings.video.preview_image
            -%}
            {{ block.settings.video | video_tag:
                image_size: "600x",
                poster: poster,
                autoplay: false,
                loop: true,
                muted: true,
                controls: true,
                class: 'aarus-spotted__video'
            }}
          {%- elsif block.settings.poster_image != blank -%}
            <img src="{{ block.settings.poster_image | image_url: width: 600 }}"
                 alt="{{ block.settings.name | escape }}"
                 class="aarus-spotted__image"
                 loading="lazy"
                 width="{{ block.settings.poster_image.width }}"
                 height="{{ block.settings.poster_image.height }}">
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'aarus-spotted__image placeholder-svg' }}
          {%- endif -%}

          {%- if block.settings.product_link != blank -%}
            <a href="{{ block.settings.product_link }}" class="aarus-spotted__tag">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                <line x1="7" y1="7" x2="7.01" y2="7"></line>
              </svg>
              {{ block.settings.product_label }}
            </a>
          {%- endif -%}
        </div>

        <div class="aarus-spotted__info">
          <div class="aarus-spotted__author">
            {{ block.settings.name }}
            {%- if block.settings.handle != blank -%}
              <span class="aarus-spotted__handle">{{ block.settings.handle }}</span>
            {%- endif -%}
          </div>
          {%- if block.settings.caption != blank -%}
            <p class="aarus-spotted__caption">{{ block.settings.caption }}</p>
          {%- endif -%}
        </div>

      </div>
    {%- endfor -%}
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const videos = document.querySelectorAll('.aarus-spotted-{{ section.id }} .aarus-spotted__video');
  if (videos.length === 0) return;

  const observer = new IntersectionObserver((entries) => {
    // Check if the user prefers reduced motion
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    
    entries.forEach(entry => {
      const video = entry.target;
      if (entry.isIntersecting) {
        if (!prefersReducedMotion && video.paused) {
          // Play only if reduced motion is false, resolving "must not all autoplay simultaneously"
          // by only playing when scrolled into view.
          video.play().catch(e => console.log('Autoplay prevented:', e));
        }
      } else {
        video.pause();
      }
    });
  }, {
    threshold: 0.6 // Trigger when 60% of the video is visible
  });

  videos.forEach(video => observer.observe(video));
});
</script>

{% schema %}
{
  "name": "Customer Sightings",
  "tag": "section",
  "class": "section",
  "max_blocks": 10,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Spotted in your festive era"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "ugc",
      "name": "Customer Post",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "Videos are muted and will autoplay when scrolled into view."
        },
        {
          "type": "image_picker",
          "id": "poster_image",
          "label": "Photo / Video Poster",
          "info": "Used as the image if no video is provided, or as the video poster frame."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Customer Name",
          "default": "Aisha Patel"
        },
        {
          "type": "text",
          "id": "handle",
          "label": "Instagram Handle",
          "default": "@aishastyles"
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption",
          "default": "Wearing the maroon lehenga for my best friend's sangeet!"
        },
        {
          "type": "url",
          "id": "product_link",
          "label": "Product Link",
          "info": "Adds a shopping tag overlay to the media."
        },
        {
          "type": "text",
          "id": "product_label",
          "label": "Product Tag Text",
          "default": "Shop the look"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer Sightings",
      "blocks": [
        { "type": "ugc" },
        { "type": "ugc" },
        { "type": "ugc" },
        { "type": "ugc" }
      ]
    }
  ]
}
{% endschema %}
