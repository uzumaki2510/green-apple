<section class="aarus-custom-order-form color-{{ section.settings.color_scheme }} spacing-style" style="--padding-top: {{ section.settings.padding_top }}px; --padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width aarus-custom-order-form__container">
    
    <div class="aarus-custom-order-form__header">
      {% if section.settings.heading != blank %}
        <h2 class="h2 aarus-custom-order-form__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.body != blank %}
        <p class="aarus-custom-order-form__body">{{ section.settings.body | escape }}</p>
      {% endif %}
    </div>

    {% form 'contact', class: 'aarus-custom-order-form__form' %}
      {%- if form.posted_successfully? -%}
        <div class="aarus-custom-order-form__message aarus-custom-order-form__message--success" tabindex="-1" autofocus>
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><polyline points="20 6 9 17 4 12"></polyline></svg>
          <p>{{ section.settings.success_message | escape }}</p>
        </div>
      {%- elsif form.errors -%}
        <div class="aarus-custom-order-form__message aarus-custom-order-form__message--error" tabindex="-1" autofocus>
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
          <p>{{ section.settings.error_message | escape }}</p>
        </div>
      {%- endif -%}

      <input type="hidden" name="contact[tags]" value="custom-order">

      <div class="aarus-custom-order-form__grid">
        <div class="field">
          <input class="field__input" type="text" id="CustomOrderForm-name" name="contact[name]" value="{{ form.name }}" autocomplete="name" placeholder="Name" required>
          <label class="field__label visually-hidden" for="CustomOrderForm-name">Name</label>
        </div>
        
        <div class="field">
          <input class="field__input" type="email" id="CustomOrderForm-email" name="contact[email]" value="{{ form.email }}" spellcheck="false" autocapitalize="off" autocomplete="email" placeholder="Email" required>
          <label class="field__label visually-hidden" for="CustomOrderForm-email">Email</label>
        </div>
      </div>

      <div class="field">
        <input class="field__input" type="tel" id="CustomOrderForm-whatsapp" name="contact[whatsapp]" pattern="[0-9\-]*" value="{{ form.whatsapp }}" placeholder="WhatsApp Number (Optional)">
        <label class="field__label visually-hidden" for="CustomOrderForm-whatsapp">WhatsApp Number</label>
      </div>

      <div class="aarus-custom-order-form__grid">
        <div class="field">
          <input class="field__input" type="text" id="CustomOrderForm-product" name="contact[product]" placeholder="Product or Category" required>
          <label class="field__label visually-hidden" for="CustomOrderForm-product">Product or Category</label>
        </div>

        <div class="field">
          <input class="field__input" type="text" id="CustomOrderForm-occasion" name="contact[occasion]" placeholder="Occasion" required>
          <label class="field__label visually-hidden" for="CustomOrderForm-occasion">Occasion</label>
        </div>
      </div>

      <div class="aarus-custom-order-form__grid">
        <div class="field">
          <input class="field__input" type="text" id="CustomOrderForm-color" name="contact[color]" placeholder="Preferred Color" required>
          <label class="field__label visually-hidden" for="CustomOrderForm-color">Preferred Color</label>
        </div>

        <div class="field">
          <input class="field__input" type="text" id="CustomOrderForm-size" name="contact[size]" placeholder="Preferred Size" required>
          <label class="field__label visually-hidden" for="CustomOrderForm-size">Preferred Size</label>
        </div>
      </div>

      <div class="aarus-custom-order-form__grid">
        <div class="field">
          <input class="field__input" type="date" id="CustomOrderForm-date" name="contact[required_by]" placeholder="Required by date (Optional)">
          <label class="field__label visually-hidden" for="CustomOrderForm-date">Required by date</label>
        </div>

        <div class="field">
          <select class="field__input" id="CustomOrderForm-budget" name="contact[budget]">
            <option value="" disabled selected>Budget Range (Optional)</option>
            <option value="Under ₹10,000">Under ₹10,000</option>
            <option value="₹10,000 - ₹25,000">₹10,000 - ₹25,000</option>
            <option value="₹25,000 - ₹50,000">₹25,000 - ₹50,000</option>
            <option value="Over ₹50,000">Over ₹50,000</option>
          </select>
          <label class="field__label visually-hidden" for="CustomOrderForm-budget">Budget Range</label>
        </div>
      </div>

      <div class="field">
        <input class="field__input" type="url" id="CustomOrderForm-inspiration" name="contact[inspiration_url]" placeholder="Inspiration Image URL (Optional - Drive/Pinterest/etc.)">
        <label class="field__label visually-hidden" for="CustomOrderForm-inspiration">Inspiration Image URL</label>
      </div>

      <div class="field">
        <textarea class="field__input aarus-custom-order-form__textarea" id="CustomOrderForm-details" name="contact[body]" rows="5" placeholder="Additional Details" required></textarea>
        <label class="field__label visually-hidden" for="CustomOrderForm-details">Additional Details</label>
      </div>

      {% if section.settings.consent_text != blank %}
        <div class="aarus-custom-order-form__consent">
          <p>{{ section.settings.consent_text | escape }} 
            {% if section.settings.privacy_url != blank %}
              <a href="{{ section.settings.privacy_url }}">Privacy Policy</a>.
            {% endif %}
          </p>
        </div>
      {% endif %}

      <div class="aarus-custom-order-form__submit-wrapper">
        <button type="submit" class="button button--primary aarus-custom-order-form__submit">
          {{ section.settings.button_text | escape }}
        </button>
      </div>
      
    {% endform %}
  </div>
</section>

{% stylesheet %}
  .aarus-custom-order-form {
    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
    background-color: var(--color-background);
  }

  .aarus-custom-order-form__container {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .aarus-custom-order-form__header {
    text-align: center;
  }

  .aarus-custom-order-form__heading {
    margin-top: 0;
    margin-bottom: 1rem;
    font-family: var(--font-heading-family);
    color: var(--aarus-indigo);
  }

  .aarus-custom-order-form__body {
    margin: 0;
    color: var(--aarus-indigo);
    opacity: 0.8;
  }

  .aarus-custom-order-form__form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    background: var(--aarus-ivory);
    padding: 2.5rem;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
  }

  .aarus-custom-order-form__grid {
    display: grid;
    gap: 1.5rem;
  }

  @media screen and (min-width: 750px) {
    .aarus-custom-order-form__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .aarus-custom-order-form__form .field__input {
    width: 100%;
    background: rgba(0,0,0,0.03);
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 8px;
    padding: 1rem;
    font-family: var(--font-body-family);
    font-size: 1rem;
    color: var(--aarus-indigo);
  }

  .aarus-custom-order-form__form .field__input:focus {
    outline: 2px solid var(--aarus-rani-pink);
    outline-offset: 2px;
    background: #fff;
  }

  .aarus-custom-order-form__textarea {
    resize: vertical;
    min-height: 120px;
  }

  .aarus-custom-order-form__consent {
    font-size: 0.85rem;
    opacity: 0.7;
    color: var(--aarus-indigo);
    text-align: center;
  }
  
  .aarus-custom-order-form__consent a {
    text-decoration: underline;
  }

  .aarus-custom-order-form__submit-wrapper {
    display: flex;
    justify-content: center;
    margin-top: 1rem;
  }

  .aarus-custom-order-form__submit {
    min-width: 250px;
  }

  .aarus-custom-order-form__message {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    border-radius: 8px;
    margin-bottom: 1rem;
  }

  .aarus-custom-order-form__message p {
    margin: 0;
    font-weight: 500;
  }

  .aarus-custom-order-form__message--success {
    background-color: rgba(76, 175, 80, 0.1);
    color: #2e7d32;
    border: 1px solid rgba(76, 175, 80, 0.2);
  }

  .aarus-custom-order-form__message--error {
    background-color: rgba(244, 67, 54, 0.1);
    color: #c62828;
    border: 1px solid rgba(244, 67, 54, 0.2);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Custom Order Form",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Request a Custom Piece"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Fill out the details below and our styling team will be in touch within 48 hours to discuss your custom creation."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Form Settings"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Submit button text",
      "default": "Submit Request"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thanks, we've received your request. We'll be in touch soon."
    },
    {
      "type": "text",
      "id": "error_message",
      "label": "Error message",
      "default": "Something went wrong. Please check the form and try again."
    },
    {
      "type": "text",
      "id": "consent_text",
      "label": "Consent text",
      "default": "By submitting this form, you agree to our terms of service and"
    },
    {
      "type": "url",
      "id": "privacy_url",
      "label": "Privacy policy link"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Aarus Custom Order Form"
    }
  ]
}
{% endschema %}
