<section class="aarus-why-us color-{{ section.settings.color_scheme }} spacing-style{% if section.settings.show_background_pattern %} aarus-why-us--pattern{% endif %}" style="--padding-top: {{ section.settings.padding_top }}px; --padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width aarus-why-us__container aarus-why-us__container--{{ section.settings.max_width }}">
    
    <div class="aarus-why-us__header" style="text-align: {{ section.settings.text_alignment }};">
      {% if section.settings.heading != blank %}
        <h2 class="aarus-why-us__heading h2">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      
      {% if section.settings.supporting_text != blank %}
        <p class="aarus-why-us__supporting-text">{{ section.settings.supporting_text | escape }}</p>
      {% endif %}
    </div>

    <div class="aarus-why-us__grid{% if section.blocks.size > 4 %} aarus-why-us__grid--mobile-scroll{% endif %} aarus-why-us__grid--{{ section.settings.desktop_columns }}-cols">
      {% for block in section.blocks %}
        <div class="aarus-why-us__item" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <div class="aarus-why-us__image-wrapper">
              {{ block.settings.image | image_url: width: 400 | image_tag: class: 'aarus-why-us__image', loading: 'lazy', alt: block.settings.heading }}
            </div>
          {% elsif block.settings.icon != blank %}
            <div class="aarus-why-us__icon svg-wrapper">
              {{ block.settings.icon }}
            </div>
          {% endif %}
          
          <div class="aarus-why-us__content">
            {% if block.settings.sticker_text != blank %}
              <span class="aarus-sticker aarus-sticker--primary">{{ block.settings.sticker_text | escape }}</span>
            {% endif %}
            
            {% if block.settings.heading != blank %}
              <h3 class="aarus-why-us__item-heading h4">{{ block.settings.heading | escape }}</h3>
            {% endif %}
            
            {% if block.settings.microcopy != blank %}
              <p class="aarus-why-us__microcopy">{{ block.settings.microcopy | escape }}</p>
            {% endif %}
            
            {% if block.settings.description != blank %}
              <div class="aarus-why-us__description">{{ block.settings.description }}</div>
            {% endif %}
            
            {% if block.settings.link != blank and block.settings.link_label != blank %}
              <a href="{{ block.settings.link }}" class="aarus-why-us__link">{{ block.settings.link_label | escape }}</a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

  </div>
</section>

{% stylesheet %}
  .aarus-why-us {
    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
    background-color: var(--color-background);
    position: relative;
    overflow: hidden;
  }
  
  .aarus-why-us--pattern::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: radial-gradient(circle, var(--aarus-rani-pink) 30%, transparent 40%);
    background-size: 16px 16px;
    background-repeat: repeat;
    opacity: 0.05;
    pointer-events: none;
    z-index: 0;
  }

  .aarus-why-us__container {
    position: relative;
    z-index: 1;
  }
  
  .aarus-why-us__container--narrow {
    max-width: 900px;
  }

  .aarus-why-us__header {
    margin-bottom: 4rem;
  }

  .aarus-why-us__heading {
    margin-bottom: 1rem;
    font-family: var(--font-heading-family);
    color: var(--aarus-indigo);
  }

  .aarus-why-us__supporting-text {
    font-size: 1.1rem;
    color: var(--aarus-indigo);
    opacity: 0.8;
    max-width: 600px;
    margin: 0 auto;
  }
  
  /* Reset max-width when left aligned */
  .aarus-why-us__header[style*="left"] .aarus-why-us__supporting-text {
    margin-left: 0;
  }

  .aarus-why-us__grid {
    display: grid;
    gap: 2rem;
  }

  .aarus-why-us__grid--2-cols { grid-template-columns: repeat(2, 1fr); }
  .aarus-why-us__grid--3-cols { grid-template-columns: repeat(3, 1fr); }
  .aarus-why-us__grid--4-cols { grid-template-columns: repeat(4, 1fr); }

  .aarus-why-us__item {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .aarus-why-us__image-wrapper {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 12px;
    overflow: hidden;
    background-color: rgba(0,0,0,0.03);
  }

  .aarus-why-us__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .aarus-why-us__icon {
    width: 48px;
    height: 48px;
    color: var(--aarus-marigold);
  }
  
  .aarus-why-us__icon svg {
    width: 100%;
    height: 100%;
  }

  .aarus-why-us__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .aarus-why-us__item-heading {
    margin: 0;
    font-family: var(--font-heading-family);
    color: var(--aarus-indigo);
  }
  
  .aarus-why-us__microcopy {
    font-size: 0.85rem;
    font-style: italic;
    color: var(--aarus-mehndi);
    margin: 0;
  }

  .aarus-why-us__description {
    font-size: 0.95rem;
    color: var(--color-foreground);
    line-height: 1.5;
  }

  .aarus-why-us__link {
    font-family: var(--font-heading-family);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    color: var(--aarus-rani-pink);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .aarus-why-us__link:hover {
    color: var(--aarus-indigo);
  }

  @media screen and (max-width: 749px) {
    .aarus-why-us__grid {
      grid-template-columns: 1fr;
    }
    
    .aarus-why-us__grid--mobile-scroll {
      display: flex;
      flex-wrap: nowrap;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 1rem;
      padding-bottom: 2rem;
      -webkit-overflow-scrolling: touch;
      margin-right: -1.5rem;
      padding-right: 1.5rem;
    }
    
    .aarus-why-us__grid--mobile-scroll::-webkit-scrollbar {
      display: none;
    }
    
    .aarus-why-us__grid--mobile-scroll .aarus-why-us__item {
      scroll-snap-align: start;
      flex: 0 0 85%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Aarus Why Us",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Made for the moment. Rooted in the craft."
    },
    {
      "type": "textarea",
      "id": "supporting_text",
      "label": "Supporting copy",
      "default": "Festive pieces and handcrafted details designed to be worn, styled, repeated, and remembered."
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "max_width",
      "label": "Maximum width",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "narrow", "label": "Narrow" }
      ],
      "default": "standard"
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Desktop columns",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_background_pattern",
      "label": "Show Bandhani dot pattern background",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "trust_point",
      "name": "Trust Point",
      "settings": [
        {
          "type": "html",
          "id": "icon",
          "label": "Custom SVG Icon",
          "info": "Paste inline SVG code"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Optional Image (overrides icon)"
        },
        {
          "type": "text",
          "id": "sticker_text",
          "label": "Optional Sticker Label"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Small-batch drops"
        },
        {
          "type": "text",
          "id": "microcopy",
          "label": "Optional Gujarati/Hindi microcopy"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>We produce in small batches to reduce waste and ensure highest quality details.</p>"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Optional Link"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Learn more"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Aarus Why Us",
      "blocks": [
        { "type": "trust_point", "settings": { "heading": "Small-batch drops" } },
        { "type": "trust_point", "settings": { "heading": "Thoughtful sourcing" } },
        { "type": "trust_point", "settings": { "heading": "Craft-led details" } }
      ]
    }
  ]
}
{% endschema %}
