{{ 'aarus-contact.css' | asset_url | stylesheet_tag }}

<section class="aarus-contact-section color-{{ section.settings.color_scheme }}" data-section-id="{{ section.id }}">
  {% if section.settings.show_pattern %}
    <div class="aarus-contact-hero__pattern"></div>
  {% endif %}

  <div class="aarus-contact-hero{% if section.settings.image_position == 'right' %} aarus-contact-hero--image-right{% endif %}">
    
    <div class="aarus-contact-hero__media">
      {%- if section.settings.image != blank -%}
        <picture>
          {%- if section.settings.image_mobile != blank -%}
            <source media="(max-width: 899px)" srcset="{{ section.settings.image_mobile | image_url: width: 800 }}">
          {%- endif -%}
          {{ section.settings.image | image_url: width: 1400 | image_tag: class: 'aarus-contact-hero__image', loading: 'eager', fetchpriority: 'high', alt: section.settings.heading }}
        </picture>
      {%- else -%}
        <div class="aarus-photo-reviews__placeholder" style="height: 100%; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.05);">
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}
    </div>

    <div class="aarus-contact-hero__content" style="text-align: {{ section.settings.text_alignment }}; {% if section.settings.text_alignment == 'center' %}align-items: center;{% endif %}">
      
      {% if section.settings.logo != blank %}
        {{ section.settings.logo | image_url: width: 360 | image_tag: class: 'aarus-contact-hero__logo', loading: 'eager', alt: shop.name }}
      {% endif %}

      {% if section.settings.eyebrow != blank %}
        <p class="aarus-contact-hero__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}
      
      {% if section.settings.heading != blank %}
        <h1 class="aarus-contact-hero__heading">{{ section.settings.heading | escape }}</h1>
      {% endif %}
      
      {% if section.settings.body != blank %}
        <p class="aarus-contact-hero__body">{{ section.settings.body | escape }}</p>
      {% endif %}
      
      <div class="aarus-contact-hero__actions" style="{% if section.settings.text_alignment == 'center' %}justify-content: center;{% endif %}">
        {% if section.settings.button_link != blank %}
          <a href="{{ section.settings.button_link }}" class="button button--primary">
            {{ section.settings.button_label | escape }}
          </a>
        {% endif %}

        {% if section.settings.whatsapp_url != blank %}
          <a href="{{ section.settings.whatsapp_url }}" target="_blank" rel="noopener" class="button button--secondary aarus-custom-order__whatsapp">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            {{ section.settings.whatsapp_label | escape }}
          </a>
        {% endif %}
      </div>
      
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop image",
      "info": "Upload the desktop hero image here. Recommended ratio: 16:9 or similar."
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image",
      "info": "Upload the mobile hero image here. Recommended ratio: 9:16."
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo overlay"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Come say hi"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Let’s make something beautiful together."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Supporting copy",
      "default": "Questions about sizing, styling, shipping, or a custom festive look? We’re here to help."
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Send us a message"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "WhatsApp Support"
    },
    {
      "type": "text",
      "id": "whatsapp_label",
      "label": "Button label",
      "default": "Chat on WhatsApp"
    },
    {
      "type": "url",
      "id": "whatsapp_url",
      "label": "WhatsApp URL",
      "info": "Leave blank to hide. Example: https://wa.me/1234567890"
    },
    {
      "type": "header",
      "content": "Design Settings"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Desktop image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "checkbox",
      "id": "show_pattern",
      "label": "Show decorative pattern",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Aarus Contact Hero"
    }
  ]
}
{% endschema %}
