{%- style -%}
  .shop-by-vibe-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
  }

  @media screen and (min-width: 750px) {
    .shop-by-vibe-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .vibe-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .vibe-header__title {
    font-family: var(--font-heading-family);
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .vibe-grid {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: 1.5rem;
    padding: 0 1.5rem 2rem 1.5rem;
    -webkit-overflow-scrolling: touch;
    scroll-padding-left: 1.5rem;
    /* Hide scrollbar but keep functionality */
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .vibe-grid::-webkit-scrollbar {
    display: none;
  }

  .vibe-grid::after {
    content: '';
    flex: 0 0 1px;
    width: 1px;
    padding-right: 0.5rem; /* Tiny buffer at the end */
  }

  .vibe-card {
    flex: 0 0 80vw;
    scroll-snap-align: start;
    position: relative;
    display: block;
    height: 450px;
    border-radius: 0; /* Editorial, no excessive rounded cards */
    overflow: hidden;
    text-decoration: none;
    background-color: #000; /* Fallback for loading */
    color: #fff;
    /* Strong focus state */
    outline: none;
  }

  .vibe-card:focus-visible {
    outline: 3px solid currentColor;
    outline-offset: 4px;
    z-index: 10;
  }

  .vibe-card__image-wrapper {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .vibe-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .vibe-card:hover .vibe-card__image {
    transform: scale(1.05);
  }

  /* Dark gradient overlay to ensure text contrast */
  .vibe-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0) 100%);
    z-index: 2;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .vibe-card:hover::after {
    opacity: 0.9;
  }

  .vibe-card__content {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 2rem 1.5rem;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .vibe-card__title {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0;
    line-height: 1.1;
    color: #ffffff;
  }

  .vibe-card__caption {
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    margin: 0;
    color: #f0f0f0;
    opacity: 0.9;
    font-style: italic;
  }

  .vibe-card__sticker {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background-color: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
    padding: 0.4rem 1rem;
    font-family: var(--font-heading-family);
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    z-index: 4;
    transform: rotate(4deg);
    box-shadow: 3px 3px 0px rgba(0,0,0,0.2);
  }

  /* Desktop Editorial Collage Grid */
  @media screen and (min-width: 750px) {
    .vibe-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      grid-auto-rows: minmax(280px, auto);
      gap: {{ section.settings.grid_gap }}px;
      padding: 0 3rem;
      max-width: var(--page-width, 1400px);
      margin: 0 auto;
      overflow: visible;
    }

    .vibe-grid::after {
      display: none;
    }

    .vibe-card {
      height: 100%;
      min-height: 280px;
      flex: none;
    }

    /* Asymmetrical specific spans for up to 8 items */
    .vibe-card:nth-child(1) { grid-column: span 7; grid-row: span 2; }
    .vibe-card:nth-child(2) { grid-column: span 5; grid-row: span 1; }
    .vibe-card:nth-child(3) { grid-column: span 5; grid-row: span 2; }
    .vibe-card:nth-child(4) { grid-column: span 7; grid-row: span 1; }
    .vibe-card:nth-child(5) { grid-column: span 4; grid-row: span 2; }
    .vibe-card:nth-child(6) { grid-column: span 8; grid-row: span 2; }
    .vibe-card:nth-child(7) { grid-column: span 6; grid-row: span 1; }
    .vibe-card:nth-child(8) { grid-column: span 6; grid-row: span 1; }

    /* Adjust font sizes based on size of card */
    .vibe-card:nth-child(1) .vibe-card__title,
    .vibe-card:nth-child(6) .vibe-card__title {
      font-size: 3.5rem;
    }
    
    .vibe-card:nth-child(4) .vibe-card__title,
    .vibe-card:nth-child(7) .vibe-card__title,
    .vibe-card:nth-child(8) .vibe-card__title {
      font-size: 2.5rem;
    }

    .vibe-card__content {
      padding: 2.5rem;
    }

    .vibe-card__sticker {
      top: 1.5rem;
      right: 1.5rem;
      padding: 0.6rem 1.2rem;
      font-size: 0.9rem;
    }
  }
  
  @media (prefers-reduced-motion: reduce) {
    .vibe-card__image,
    .vibe-card::after {
      transition: none;
    }
    .vibe-card:hover .vibe-card__image {
      transform: none;
    }
    .vibe-grid {
      scroll-behavior: auto;
    }
  }
{%- endstyle -%}

<section class="shop-by-vibe-{{ section.id }} color-{{ section.settings.color_scheme }}" data-section-id="{{ section.id }}">
  {%- if section.settings.heading != blank -%}
    <div class="vibe-header">
      <h2 class="vibe-header__title">{{ section.settings.heading }}</h2>
    </div>
  {%- endif -%}

  <div class="vibe-grid">
    {%- for block in section.blocks -%}
      {%- liquid
        assign collection = block.settings.collection
        assign target_image = block.settings.image | default: collection.image | default: collection.products.first.featured_image
        assign title = block.settings.title | default: collection.title | default: 'Collection'
        assign link = block.settings.link | default: collection.url | default: '#'
      -%}

      <a href="{{ link }}" class="vibe-card" {{ block.shopify_attributes }} aria-label="Shop {{ title }}">
        <div class="vibe-card__image-wrapper">
          {%- if target_image != blank -%}
            <img src="{{ target_image | image_url: width: 1200 }}"
                 alt="{{ target_image.alt | escape }}"
                 class="vibe-card__image"
                 loading="lazy"
                 width="{{ target_image.width }}"
                 height="{{ target_image.height }}">
          {%- else -%}
            {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'vibe-card__image placeholder-svg' }}
          {%- endif -%}
        </div>

        {%- if block.settings.sticker != blank -%}
          <div class="vibe-card__sticker">{{ block.settings.sticker }}</div>
        {%- endif -%}

        <div class="vibe-card__content">
          <h3 class="vibe-card__title">{{ title }}</h3>
          {%- if block.settings.caption != blank -%}
            <p class="vibe-card__caption">{{ block.settings.caption }}</p>
          {%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Shop by Vibe",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Vibe"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Desktop Layout"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Grid Spacing",
      "default": 16
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Vibe Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Image",
          "info": "Overrides the collection image."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom Title",
          "info": "Overrides the collection title."
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Playful Caption",
          "default": "Find your aesthetic."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Custom Link",
          "info": "Overrides the collection URL."
        },
        {
          "type": "text",
          "id": "sticker",
          "label": "Optional Sticker",
          "info": "e.g., 'Trending', 'New'. Leave blank to hide."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Vibe",
      "blocks": [
        {
          "type": "collection",
          "settings": {
            "title": "Garba Nights",
            "caption": "Swirl-ready lehengas and oxidised silver.",
            "sticker": "Trending"
          }
        },
        {
          "type": "collection",
          "settings": {
            "title": "Wedding Guest Energy",
            "caption": "Show up and show out without upstaging the bride."
          }
        },
        {
          "type": "collection",
          "settings": {
            "title": "Tiny Festive Stars",
            "caption": "Miniature outfits for maximum joy.",
            "sticker": "New"
          }
        },
        {
          "type": "collection",
          "settings": {
            "title": "Everyday Desi",
            "caption": "Breezy kurtas for chai runs."
          }
        },
        {
          "type": "collection",
          "settings": {
            "title": "Main Character Jewellery",
            "caption": "Statement pieces that start conversations.",
            "sticker": "Bestsellers"
          }
        },
        {
          "type": "collection",
          "settings": {
            "title": "Carry the Colour",
            "caption": "Handcrafted potlis and bold totes."
          }
        }
      ]
    }
  ]
}
{% endschema %}
